# ---- Build output (safe to delete; regenerated by cmake --preset) ----
/build/
build/
/cmake-build-*/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json

# ---- vcpkg (manifest mode installs here; safe to delete, re-fetched on configure) ----
/vcpkg_installed/
vcpkg_installed/

# ---- Compiled artifacts ----
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe

# ---- IDE / editor / local caches ----
.vscode/
.idea/
.cache/
*.swp
*~

# ---- OS cruft ----
.DS_Store
Thumbs.db

# ---- Subagent-Driven-Development workspace (also self-ignored; explicit here) ----
# Briefs, implementer reports, review packages, and the progress ledger.
# This is scratch — safe to delete between sessions. The durable resume state
# lives in docs/superpowers/PHASE0-EXECUTION-GUIDE.md (committed).
/.superpowers/
.claude/
.codegraph/
.mcp.json

# ---- Vagrant & VM Test Artifacts ----
# Vagrant stores machine state, SSH keys, and synced folder metadata here
.vagrant/

# The 64MB raw USB image created for QEMU testing
/test/vm/spare.img

# Host-side serial and USB trace logs generated by the Vagrantfile
/test/vm/devmgr-vm-serial.log
/test/vm/devmgr-vm-usb-trace.log

# ---- Qt Auto-generated files ----
# (CMake usually puts these in build/, but sometimes they leak into source)
moc_*.cpp
qrc_*.cpp
ui_*.h

# ---- Patch & Merge artifacts ----
*.orig
*.rej
*.bak

# ---- Python (for any helper scripts) ----
__pycache__/
*.py[cod]
dist/
