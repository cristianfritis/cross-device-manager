# Disposable VM for kernel-level tests (Phase 4+)
SPARE_IMG  = File.expand_path(ENV.fetch("DEVMGR_SPARE_IMG",  "spare.img"), __dir__)
SERIAL_LOG = File.expand_path(ENV.fetch("DEVMGR_SERIAL_LOG", "devmgr-vm-serial.log"), __dir__)

Vagrant.configure("2") do |config|
  config.vm.box = "generic/ubuntu2204"
  config.vm.hostname = "devmgr-test"

  config.vm.synced_folder ".", "/vagrant", disabled: true

  config.vm.provider "libvirt" do |lv|
    lv.memory = 4096 # Bumped to 4GB for vcpkg compilation
    lv.cpus = 4      # Bumped to 4 cores for faster builds

    lv.serial type: "file", source: { path: SERIAL_LOG }

    if File.exist?(SPARE_IMG)
      lv.qemuargs value: "-drive"
      lv.qemuargs value: "if=none,id=usbstick,format=raw,file=#{SPARE_IMG}"
      lv.qemuargs value: "-device"
      lv.qemuargs value: "qemu-xhci,id=xhci,addr=0x8"
      lv.qemuargs value: "-device"
      lv.qemuargs value: "usb-storage,bus=xhci.0,drive=usbstick"
    end
  end

  config.vm.provision "shell", inline: <<-SHELL
    export DEBIAN_FRONTEND=noninteractive
    apt-get update
    apt-get install -y build-essential cmake ninja-build pkg-config \
      libudev-dev libkmod-dev git curl zip unzip tar \
      libsystemd-dev libdbus-1-dev libpolkit-gobject-1-dev

    # Build and install sdbus-c++ v2 from source
    if [ ! -d /usr/local/include/sdbus-c++ ]; then
      cd /tmp
      rm -rf sdbus-cpp
      git clone --depth 1 https://github.com/Kistler-Group/sdbus-cpp.git
      cd sdbus-cpp
      cmake -B build -G Ninja -DCMAKE_BUILD_TYPE=Release
      cmake --build build
      cmake --install build
      ldconfig
    fi

    # Install vcpkg globally for the vagrant user
    if [ ! -d /home/vagrant/vcpkg ]; then
      git clone https://github.com/microsoft/vcpkg.git /home/vagrant/vcpkg
      /home/vagrant/vcpkg/bootstrap-vcpkg.sh
      chown -R vagrant:vagrant /home/vagrant/vcpkg
    fi
  SHELL
end
